{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "promotion_manifest.schema.json",
  "title": "Promotion manifest",
  "type": "object",
  "required": [
    "attempt_id",
    "profile",
    "publication_mode",
    "promoted_at",
    "reward_card_hash",
    "semantic_verification_hash",
    "rewards_config_hash",
    "content_hashes",
    "verified",
    "blocking_rewards"
  ],
  "properties": {
    "attempt_id": {"type": "string"},
    "profile": {"type": "string"},
    "publication_mode": {
      "type": "string",
      "enum": ["research", "shadow", "production", "fixture"]
    },
    "promoted_at": {"type": "string"},
    "reward_card_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "semantic_verification_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "rewards_config_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "content_hashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    },
    "verified": {"const": true},
    "blocking_rewards": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
